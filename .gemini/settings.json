{
  "hooksConfig": {
    "enabled": true
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $GEMINI_PROJECT_DIR/tools/hooks/ai/block-dangerous-commands.py"
          }
        ]
      },
      {
        "matcher": "write_file|replace",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $GEMINI_PROJECT_DIR/tools/hooks/ai/block-dangerous-commands.py"
          }
        ]
      }
    ]
  },
  "chatCompression": {
    "contextPercentageThreshold": 0.5
  },
  "ui": {
    "autoApprove": false,
    "showToolCalls": true
  },
  "context": {
    "files": [
      "AGENTS.md",
      "GEMINI.md"
    ]
  },
  "general": {
    "defaultApprovalMode": "auto_edit"
  },
  "security": {
    "enablePermanentToolApproval": true,
    "autoAddToPolicyByDefault": true
  },
  "skills": {
    "disabled": [
      "restore",
      "ghi-finalize",
      "checkpoint",
      "codex-plan",
      "codex-implement",
      "codex-review",
      "codex-adversarial-review",
      "delegate-claude-plan",
      "delegate-claude-implement",
      "delegate-claude-review",
      "delegate-claude-adversarial-review",
      "delegate-gemini-plan",
      "delegate-gemini-implement",
      "delegate-gemini-review",
      "delegate-gemini-adversarial-review",
      "delegate-copilot-plan",
      "delegate-copilot-implement",
      "delegate-copilot-review",
      "delegate-copilot-adversarial-review",
      "multi-plan",
      "multi-review",
      "multi-adversarial-review",
      "antigravity-plan",
      "antigravity-implement",
      "antigravity-review",
      "antigravity-adversarial-review"
    ]
  }
}
