{
  "hooksConfig": {
    "enabled": true
  },
  "hooks": {
    "BeforeTool": [
      {
        "matcher": "run_shell_command",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $GEMINI_PROJECT_DIR/tools/hooks/ai/block-dangerous-commands.py"
          }
        ]
      }
    ]
  },
  "ui": {
    "autoApprove": false,
    "showToolCalls": true
  },
  "context": {
    "files": [
      "AGENTS.md",
      "GEMINI.md"
    ]
  },
  "general": {
    "defaultApprovalMode": "auto_edit"
  },
  "security": {
    "enablePermanentToolApproval": true,
    "autoAddToPolicyByDefault": true
  },
  "skills": {
    "disabled": [
      "restore",
      "ghissue-plan",
      "ghissue-implement",
      "ghissue-finalize",
      "checkpoint"
    ]
  }
}
